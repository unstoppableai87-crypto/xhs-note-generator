GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Shared Google Sheets + Drive queue (see SETUP_CLOUD.md)
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
GOOGLE_SHEET_ID=your-google-sheet-id-here
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id-here

# Shared passcode customers must enter on the customer_form.py intake page.
# Leave blank to disable the passcode gate (not recommended once the link is public).
CUSTOMER_PASSCODE=
