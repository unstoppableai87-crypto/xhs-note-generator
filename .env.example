GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Shared Supabase queue (see SETUP_CLOUD.md) - free tier, no credit card needed.
SUPABASE_URL=your-supabase-project-url-here
SUPABASE_KEY=your-supabase-service-role-key-here
SUPABASE_BUCKET=photos

# app.py serves both roles from one URL - which passcode you type in decides
# what you see. Guests entering CUSTOMER_PASSCODE get 创建笔记/封面图 only;
# entering CREATOR_PASSCODE also unlocks 📋 待发布队列. Leave both blank to
# disable the gate entirely (fine for local-only use, not once deployed
# publicly - that would let anyone burn your Gemini quota).
CUSTOMER_PASSCODE=
CREATOR_PASSCODE=
