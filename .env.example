GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Shared Supabase queue (see SETUP_CLOUD.md) - free tier, no credit card needed.
SUPABASE_URL=your-supabase-project-url-here
SUPABASE_KEY=your-supabase-service-role-key-here
SUPABASE_BUCKET=photos

# Shared passcode customers must enter on the customer_form.py intake page.
# Leave blank to disable the passcode gate (not recommended once the link is public).
CUSTOMER_PASSCODE=

# Passcode gating your own creator app (app.py) once it's deployed publicly.
# Use a different value than CUSTOMER_PASSCODE. Leave blank to disable (not
# recommended once the link is public - it would let anyone burn your Gemini quota).
CREATOR_PASSCODE=
